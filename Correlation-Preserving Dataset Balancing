# Imprimir la correlación de los descriptores con la clase
print("Correlación de los descriptores con la clase en los datos originales:\n", corr_with_class_original)
print("Correlación de los descriptores con la clase después del submuestreo estratificado:\n", corr_with_class_best_subsampled)
