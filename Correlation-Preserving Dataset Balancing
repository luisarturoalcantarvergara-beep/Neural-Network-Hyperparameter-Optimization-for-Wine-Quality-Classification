import pandas as pd
import numpy as np

# Cargar el CSV
df = pd.read_csv('winequalit-white5.csv')

# Suponiendo que la columna de etiquetas se llama 'clase'
X = df.drop('clase', axis=1)  # Características
y = df['clase']  # Etiquetas

# Dividir los datos en clases mayoritaria y minoritaria
majority_class = df[df['clase'] == 1]
minority_class = df[df['clase'] == 0]

# Imprimir número de instancias antes del balanceo
print("Número de instancias antes del balanceo:")
print(f"Clase 0: {len(minority_class)}")
print(f"Clase 1: {len(majority_class)}")

# Definir rangos para cada descriptor clave
def get_bins(data, num_bins):
    return np.linspace(data.min(), data.max(), num_bins)

# Función para realizar submuestreo estratificado
def stratified_subsample(data, bins, column_name, target_count):
    subsampled_data = pd.DataFrame()
    for i in range(len(bins) - 1):
        bin_data = data[(data[column_name] > bins[i]) & (data[column_name] <= bins[i + 1])]
        subsample_count = int(len(bin_data) / len(data) * target_count)
        if len(bin_data) < subsample_count:
            subsample_count = len(bin_data)
        subsampled_data = pd.concat([subsampled_data, bin_data.sample(n=subsample_count, random_state=42)])
    return subsampled_data

# Definir el número objetivo de instancias para las clases balanceadas
target_count = len(minority_class)

# Variables para rastrear la mejor combinación y su correlación
best_corr = float('inf')
best_combination = (0, 0, 0, 0)
best_combined_subsampled = None

# Ciclo para probar todas las combinaciones de bins
for bins_a in range(2, 16):
    for bins_va in range(2, 16):
        for bins_d in range(2, 16):
            for bins_ts in range(2, 16):
                bins_alcohol = get_bins(majority_class['alcohol'], bins_a)
                bins_volatile_acidity = get_bins(majority_class['volatile acidity'], bins_va)
                bins_density = get_bins(majority_class['density'], bins_d)
                bins_total_sulfur_dioxide = get_bins(majority_class['total sulfur dioxide'], bins_ts)

                subsampled_alcohol = stratified_subsample(majority_class, bins_alcohol, 'alcohol', target_count)
                subsampled_volatile_acidity = stratified_subsample(majority_class, bins_volatile_acidity, 'volatile acidity', target_count)
                subsampled_density = stratified_subsample(majority_class, bins_density, 'density', target_count)
                subsampled_total_sulfur_dioxide = stratified_subsample(majority_class, bins_total_sulfur_dioxide, 'total sulfur dioxide', target_count)

                combined_subsampled = pd.concat([subsampled_alcohol, subsampled_volatile_acidity, subsampled_density, subsampled_total_sulfur_dioxide])
                combined_subsampled = combined_subsampled.drop_duplicates()

                balanced_majority_class = combined_subsampled.sample(n=target_count, random_state=42)
                final_combined = pd.concat([balanced_majority_class, minority_class])

                corr_with_class_subsampled = final_combined.corr()['clase'].drop('clase')

                if abs(corr_with_class_subsampled['alcohol']) < best_corr:
                    best_corr = abs(corr_with_class_subsampled['alcohol'])
                    best_combination = (bins_a, bins_va, bins_d, bins_ts)
                    best_combined_subsampled = final_combined

# Guardar los datos nuevos en un archivo CSV
best_combined_subsampled.to_csv('winequality-white-best-balanced.csv', index=False)

# Calcular las matrices de correlación
corr_original = df.corr()
corr_best_subsampled = best_combined_subsampled.corr()

# Calcular la correlación de los descriptores con la clase
corr_with_class_original = df.corr()['clase'].drop('clase')
corr_with_class_best_subsampled = best_combined_subsampled.corr()['clase'].drop('clase')

# Imprimir número de instancias después del balanceo
print("Número de instancias después del balanceo:")
print(f"Clase 0: {len(best_combined_subsampled[best_combined_subsampled['clase'] == 0])}")
print(f"Clase 1: {len(best_combined_subsampled[best_combined_subsampled['clase'] == 1])}")

# Imprimir la mejor combinación de bins
print("Mejor combinación de bins:", best_combination)

